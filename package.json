{
  "name": "tanstack-tiktok-analyzer",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute tiktok-analyzer-db --local --file=drizzle/0000_initial.sql",
    "check": "tsc --noEmit && vitest run",
    "sidecar": "tsx scripts/tiktok-sidecar.ts",
    "skills:update": "npx @tanstack/intent@latest install --map",
    "skills:check": "npx @tanstack/intent@latest stale"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cloudflare/vite-plugin": "1.36.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@cloudflare/vitest-pool-workers": "^0.14.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "0.31.10",
    "node-addon-api": "^8.5.0",
    "node-gyp": "^12.1.0",
    "shadcn": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2",
    "wrangler": "4.88.0"
  }
}
